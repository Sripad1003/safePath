        { "lati": 78.56, "longi": 17.382, "type": "Feature", "properties": { "mag": 1 } },
        { "lati": 78.5065, "longi": 17.4815, "type": "Feature", "properties": { "mag": 1 } },
        { "lati": 78.472, "longi": 17.533, "type": "Feature", "properties": { "mag": 1 } },
        { "lati": 78.513, "longi": 17.502, "type": "Feature", "properties": { "mag": 0 } },
        { "lati": 78.484, "longi": 17.4435, "type": "Feature", "properties": { "mag": 3 } },
        { "lati": 78.261, "longi": 17.525, "type": "Feature", "properties": { "mag": 2 } },
        { "lati": 78.448, "longi": 17.464, "type": "Feature", "properties": { "mag": 3 } },
        { "lati": 78.468, "longi": 17.518, "type": "Feature", "properties": { "mag": 1 } }
      ];

      var data = delhiData;

      // Use current data points
      function updateData() {
        var normalized = data.map(function (item) {
          return { lat: Number(item.longi), lng: Number(item.lati), mag: (item.properties && item.properties.mag) || 0 };
        });
        return normalized;
      }

      var activeData = updateData();


      var map;
      var directionsDisplay;
      var directionsService;

      function initMap(location) {
        directionsService = new google.maps.DirectionsService();
        directionsDisplay = new google.maps.DirectionsRenderer();
        var loc;
        if (location && location.coords) {
          loc = new google.maps.LatLng(location.coords.latitude, location.coords.longitude);
        } else {
          // fallback location (Delhi default)
          loc = new google.maps.LatLng(28.6139, 77.2090);
        }

        map = new google.maps.Map(document.getElementById('map'), {
          mapTypeControl: false,
          zoom: 12,
          center: loc,
          mapTypeId: 'terrain'
        });

        var marker = new google.maps.Marker({ position: loc, map: map });
        directionsDisplay.setMap(map);

        map.data.setStyle(function (feature) {
          var magnitude = feature.getProperty('mag');
          return { icon: getCircle(magnitude) };
        });

        loadDataToMap();
        new AutocompleteDirectionsHandler(map);
      }

      function loadDataToMap() {
        // Clear existing data from map
        map.data.forEach(function (feature) {
          map.data.remove(feature);
        });

        // Add dummy markers for visualization
        data.forEach(function (item) {
          map.data.add({
            geometry: new google.maps.Data.Point({ lat: Number(item.longi), lng: Number(item.lati) }),
            properties: { mag: (item.properties && item.properties.mag) || 0 }
          });
        });
      }

      function getCircle(magnitude) {
        return {
          path: google.maps.SymbolPath.CIRCLE,
          fillColor: 'red',
          fillOpacity: .2,
          scale: Math.pow(2, (magnitude || 0)) / 2,
          strokeColor: 'white',
          strokeWeight: .5
        };
      }

      /**
       * @constructor
       */
      function AutocompleteDirectionsHandler(map) {
        this.map = map;
        this.originPlaceId = null;
        this.destinationPlaceId = null;
        this.travelMode = 'WALKING';
        var originInput = document.getElementById('origin-input');
        var destinationInput = document.getElementById('destination-input');
        var modeSelector = document.getElementById('mode-selector');
        this.directionsService = new google.maps.DirectionsService;
        this.directionsDisplay = new google.maps.DirectionsRenderer;
        this.directionsDisplay.setMap(map);

        var originAutocomplete = new google.maps.places.Autocomplete(originInput, {
          fields: ['place_id', 'geometry', 'name', 'formatted_address'],
          types: ['geocode']
        });
        var destinationAutocomplete = new google.maps.places.Autocomplete(destinationInput, {
          fields: ['place_id', 'geometry', 'name', 'formatted_address'],
          types: ['geocode']
        });

        this.setupClickListener('changemode-driving', 'DRIVING');
        this.setupClickListener('changemode-walking', 'WALKING');
        this.setupClickListener('changemode-transit', 'TRANSIT');

        this.setupPlaceChangedListener(originAutocomplete, 'ORIG');
        this.setupPlaceChangedListener(destinationAutocomplete, 'DEST');

        this.map.controls[google.maps.ControlPosition.TOP_LEFT].push(originInput);
        this.map.controls[google.maps.ControlPosition.TOP_LEFT].push(destinationInput);
        this.map.controls[google.maps.ControlPosition.TOP_LEFT].push(modeSelector);
      }

      AutocompleteDirectionsHandler.prototype.setupClickListener = function (id, mode) {
        var radioButton = document.getElementById(id);
        var me = this;
        radioButton.addEventListener('click', function () {
          me.travelMode = mode;
          me.route();
        });
      };

      AutocompleteDirectionsHandler.prototype.setupPlaceChangedListener = function (autocomplete, mode) {
        var me = this;
        autocomplete.bindTo('bounds', this.map);
        autocomplete.addListener('place_changed', function () {
          var place = autocomplete.getPlace();
          if (!place.place_id) {
            window.alert("Please select an option from the dropdown list.");
            return;
          }
          if (mode === 'ORIG') {
            me.originPlaceId = place.place_id;
          } else {
            me.destinationPlaceId = place.place_id;
          }
          me.route();
        });
      };

      AutocompleteDirectionsHandler.prototype.route = function () {
        if (!this.originPlaceId || !this.destinationPlaceId) {
          return;
        }
        var me = this;

        this.directionsService.route({
          origin: { 'placeId': this.originPlaceId },
          destination: { 'placeId': this.destinationPlaceId },
          travelMode: this.travelMode,
          provideRouteAlternatives: true,
          unitSystem: google.maps.UnitSystem.METRIC
        }, function (response, status) {
          if (status === 'OK') {
            var images = [
              { url: 'https://cdn.pixabay.com/photo/2012/04/23/16/54/warning-39047_640.png', scaledSize: new google.maps.Size(28, 28) },
              { url: 'https://www.canada.ca/content/dam/hc-sc/migration/hc-sc/cps-spc/images/legislation/acts-lois/hazard-symbol-danger1.jpg', scaledSize: new google.maps.Size(28, 28) },
              { url: 'https://cdn3.iconfinder.com/data/icons/picons-weather/57/53_warning-256.png', scaledSize: new google.maps.Size(23, 23) },
              { url: 'https://upload.wikimedia.org/wikipedia/commons/thumb/e/e0/SNice.svg/220px-SNice.svg.png', scaledSize: new google.maps.Size(23, 23) },
              { url: 'https://static9.depositphotos.com/1431107/1143/i/950/depositphotos_11437164-stock-photo-green-tick.jpg', scaledSize: new google.maps.Size(23, 23) }
            ];
            var color = ["purple", "yellow", "green", "blue", "pink"];

            var dindex = [];
            console.log('routes returned:', response.routes.length);

            for (var k = 0; k < response.routes.length; k++) {
              dindex[k] = 0;
              var points = response.routes[k].overview_path;

              new google.maps.DirectionsRenderer({
                map: map,
                directions: response,
                routeIndex: k,
                unitSystem: google.maps.UnitSystem.METRIC,
                provideRouteAlternatives: true,
                polylineOptions: {
                  strokeColor: color[k % color.length],
                  strokeOpacity: 0.7,
                  strokeWeight: 10
                }
              });

              var infoWindow = new google.maps.InfoWindow();
              var posInit = null;
              var count = 0;

              for (var j = 0; j < points.length; j++) {
                for (var i = 0; i < data.length; i++) {
                  // Note: original data appears to have lat/long reversed in fields.
                  // The original code compared string slices — preserve that behavior.
                  var st1 = data[i].lati.toString();
                  st1 = st1.slice(0, (st1.indexOf(".")) + 3);
                  var st3 = data[i].longi.toString();
                  st3 = st3.slice(0, (st3.indexOf(".")) + 3);
                  var st2 = points[j].lng().toString();
                  st2 = st2.slice(0, (st2.indexOf(".")) + 3);
                  var st4 = points[j].lat().toString();
                  st4 = st4.slice(0, (st4.indexOf(".")) + 3);

                  if ((st1 === st2) && (st3 === st4)) {
                    count++;
                    posInit = new google.maps.LatLng(data[i].longi, data[i].lati);

                    var mag = data[i].properties && data[i].properties.mag;
                    if (mag === 4) {
                      new google.maps.Marker({ position: new google.maps.LatLng(data[i].longi, data[i].lati), icon: images[0], map: map });
                      dindex[k] += 4;
                    } else if (mag === 3) {
                      new google.maps.Marker({ position: new google.maps.LatLng(data[i].longi, data[i].lati), icon: images[1], map: map });
                      dindex[k] += 3;
                    } else if (mag === 2) {
                      new google.maps.Marker({ position: new google.maps.LatLng(data[i].longi, data[i].lati), icon: images[2], map: map });
                      dindex[k] += 2;
                    } else if (mag === 1) {
                      new google.maps.Marker({ position: new google.maps.LatLng(data[i].longi, data[i].lati), icon: images[3], map: map });
                      dindex[k] += 1;
                    } else {
                      // mag 0 or undefined -> no addition
                    }
                  } // end if coordinate match
                } // end for data
              } // end for points

              // avoid divide-by-zero
              if (count > 0) {
                dindex[k] /= count;
              } else {
                dindex[k] = 0;
              }

              // Message clear old div logic was here, now using sidebar
              if (k === 0) document.getElementById('route-results').innerHTML = "";

              var routeCard = document.createElement('div');
              routeCard.className = "route-card";
              routeCard.style.borderLeftColor = color[k % color.length];

              var timeTxt = response.routes[k].legs[0].duration.text;
              var distTxt = response.routes[k].legs[0].distance.text;
              var dangerVal = dindex[k].toFixed(2);

              routeCard.innerHTML = `
                <h4>Route #${k + 1}</h4>
                <p class="time"><i class="far fa-clock"></i> ${timeTxt}</p>
                <p><i class="fas fa-arrows-alt-h"></i> Distance: ${distTxt}</p>
                <p class="danger"><i class="fas fa-exclamation-triangle"></i> Danger Index: ${dangerVal}</p>
              `;

              document.getElementById('route-results').appendChild(routeCard);
              infoWindow.setPosition(posInit || response.routes[k].legs[0].start_location);
            } // end for each route

          } else {
            window.alert('Directions request failed due to ' + status);
          }
        });
      };

      $(document).ready(function () {
        // use geolocation to initialize; fallback handled inside initMap
        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(initMap, function () { initMap(); }, { timeout: 5000 });
        } else {
          initMap();
        }

        $('#location-btn').click(function () {
          if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {
              var pos = {
                lat: position.coords.latitude,
                lng: position.coords.longitude
              };
              map.setCenter(pos);
              new google.maps.Marker({ position: pos, map: map, title: "Your Location" });
            });
          }
        });

        $('#btn-delhi').click(function () {
          $(this).addClass('active').siblings().removeClass('active');
          data = delhiData;
          loadDataToMap();
          map.setCenter({ lat: 28.6139, lng: 77.2090 });
        });

        $('#btn-hyd').click(function () {
          $(this).addClass('active').siblings().removeClass('active');
          data = hydData;
          loadDataToMap();
